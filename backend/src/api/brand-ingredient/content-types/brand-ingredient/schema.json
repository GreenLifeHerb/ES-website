{
  "kind": "collectionType",
  "collectionName": "brand_ingredients",
  "info": {
    "singularName": "brand-ingredient",
    "pluralName": "brand-ingredients",
    "displayName": "Branded Ingredient"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "brand_name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "brand_name",
      "required": true
    },
    "story": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "differentiators": {
      "type": "json",
      "default": []
    },
    "related_products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    }
  }
}

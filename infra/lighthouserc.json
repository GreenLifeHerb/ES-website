{
  "ci": {
    "collect": {
      "startServerCommand": "node -e \"process.env.PORT=4180; require('./server.js')\"",
      "startServerReadyPattern": "Essence Source static site running",
      "url": [
        "http://127.0.0.1:4180/",
        "http://127.0.0.1:4180/products.html",
        "http://127.0.0.1:4180/product-green-coffee.html",
        "http://127.0.0.1:4180/resources.html",
        "http://127.0.0.1:4180/contact.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "uses-responsive-images": "warn",
        "uses-optimized-images": "warn",
        "uses-text-compression": "warn",
        "canonical": "error",
        "structured-data": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
